// Default signing values for shared/repo builds.
// Auto-selected local team overrides live in .local-signing.xcconfig (git-ignored).
// Manual local overrides can go in LocalSigning.xcconfig (git-ignored).

#include "Config/Version.xcconfig"

AVACLAW_CODE_SIGN_STYLE = Manual
AVACLAW_DEVELOPMENT_TEAM = Y5PE65HELJ

AVACLAW_APP_BUNDLE_ID = ai.avaclaw.client
AVACLAW_SHARE_BUNDLE_ID = ai.avaclaw.client.share
AVACLAW_WATCH_APP_BUNDLE_ID = ai.avaclaw.client.watchkitapp
AVACLAW_WATCH_EXTENSION_BUNDLE_ID = ai.avaclaw.client.watchkitapp.extension
AVACLAW_ACTIVITY_WIDGET_BUNDLE_ID = ai.avaclaw.client.activitywidget

AVACLAW_APP_PROFILE = ai.avaclaw.client Development
AVACLAW_SHARE_PROFILE = ai.avaclaw.client.share Development

// Keep local includes after defaults: xcconfig is evaluated top-to-bottom,
// so later assignments in local files override the defaults above.
#include? ".local-signing.xcconfig"
#include? "LocalSigning.xcconfig"
